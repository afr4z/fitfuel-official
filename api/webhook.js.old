/**
 * FitFuel Nutrition — WhatsApp Bot
 * Vercel Serverless Function
 */

const VERIFY_TOKEN = process.env.WHATSAPP_VERIFY_TOKEN;
const ACCESS_TOKEN = process.env.WHATSAPP_ACCESS_TOKEN;
const PHONE_NUMBER_ID = process.env.WHATSAPP_PHONE_NUMBER_ID;

const GRAPH_URL = `https://graph.facebook.com/v19.0/${PHONE_NUMBER_ID}/messages`;

async function sendText(to, text) {
  return post({
    messaging_product: "whatsapp",
    recipient_type: "individual",
    to,
    type: "text",
    text: { body: text },
  });
}

async function sendMainMenu(to) {
  return post({
    messaging_product: "whatsapp",
    recipient_type: "individual",
    to,
    type: "interactive",
    interactive: {
      type: "button",
      header: {
        type: "text",
        text: "🌿 FitFuel Nutrition",
      },
      body: {
        text: "Welcome! How can we help you today? Choose an option below 👇",
      },
      footer: {
        text: "Fuel your body. Feed your goals.",
      },
      action: {
        buttons: [
          {
            type: "reply",
            reply: { id: "VIEW_PLANS", title: "🥗 View Plans" },
          },
          { type: "reply", reply: { id: "ORDER_NOW", title: "🛒 Order Now" } },
          {
            type: "reply",
            reply: { id: "CONTACT_US", title: "📞 Contact Us" },
          },
        ],
      },
    },
  });
}

async function handleButtonReply(from, buttonId) {
  switch (buttonId) {
    case "VIEW_PLANS":
      await sendText(
        from,
        `🥗 *Our Nutrition Plans*\n\n` +
          `1️⃣ *Starter Plan* — ₹1,499/month\n   Basic meal plan + macros guide\n\n` +
          `2️⃣ *Performance Plan* — ₹2,999/month\n   Custom diet + weekly check-in\n\n` +
          `3️⃣ *Elite Plan* — ₹4,999/month\n   1-on-1 coaching + full meal prep\n\n` +
          `Reply with your choice and we'll get you started! 💪`,
      );
      break;

    case "ORDER_NOW":
      await sendText(
        from,
        `🛒 *Place an Order*\n\n` +
          `To get started, please share:\n` +
          `1. Your preferred plan\n` +
          `2. Your fitness goal (weight loss / muscle gain / maintenance)\n` +
          `3. Any dietary restrictions\n\n` +
          `Our team will get back to you within 2 hours! ⚡`,
      );
      break;

    case "CONTACT_US":
      await sendText(
        from,
        `📞 *Get in Touch*\n\n` +
          `📧 Email: hello@fitfuelnutrition.com\n` +
          `📱 WhatsApp: This chat!\n` +
          `🌐 Website: www.fitfuelnutrition.com\n` +
          `🕐 Support hours: Mon–Sat, 9am–7pm\n\n` +
          `We typically reply within a few hours 🙌`,
      );
      break;

    default:
      await sendMainMenu(from);
  }
}

async function handleIncomingMessage(from, message) {
  console.log("[HANDLER] from:", from, "type:", message.type);

  // Fire and forget — don't await, don't let it crash the flow
  markAsRead(message.id).catch((e) =>
    console.warn("[HANDLER] markAsRead failed:", e.message),
  );

  if (
    message.type === "interactive" &&
    message.interactive?.type === "button_reply"
  ) {
    return handleButtonReply(from, message.interactive.button_reply.id);
  }

  return sendMainMenu(from);
}

async function markAsRead(messageId) {
  await post({
    messaging_product: "whatsapp",
    status: "read",
    message_id: messageId,
  });
}

async function post(body) {
  const url = `https://graph.facebook.com/v19.0/${process.env.WHATSAPP_PHONE_NUMBER_ID}/messages`;

  console.log("[POST] URL:", url);
  console.log(
    "[POST] Token (first 20 chars):",
    process.env.WHATSAPP_ACCESS_TOKEN?.slice(0, 20),
  );
  console.log("[POST] Body:", JSON.stringify(body));

  const res = await fetch(url, {
    method: "POST",
    headers: {
      Authorization: `Bearer ${process.env.WHATSAPP_ACCESS_TOKEN}`,
      "Content-Type": "application/json",
    },
    body: JSON.stringify(body),
  });

  console.log("[POST] Status:", res.status);

  if (!res.ok) {
    const err = await res.json();
    console.error("[POST] Error:", JSON.stringify(err));
    throw new Error("Graph API request failed");
  }

  return res.json();
}
function extractMessage(body) {
  try {
    const value = body?.entry?.[0]?.changes?.[0]?.value;
    const messages = value?.messages;
    if (!messages?.length) return null;
    return { from: messages[0].from, message: messages[0] };
  } catch {
    return null;
  }
}

export default async function handler(req, res) {
  if (req.method === "GET") {
    const mode = req.query["hub.mode"];
    const token = req.query["hub.verify_token"];
    const challenge = req.query["hub.challenge"];

    if (mode === "subscribe" && token === VERIFY_TOKEN) {
      return res.status(200).send(challenge);
    }
    return res.status(403).json({ error: "Verification failed" });
  }

  if (req.method === "POST") {
    try {
      const extracted = extractMessage(req.body);
      console.log("[BOT] Extracted message:", extracted);

      if (extracted) {
        await handleIncomingMessage(extracted.from, extracted.message);
      }
    } catch (err) {
      console.error("[BOT] Error:", err);
    }

    // Send 200 AFTER all the work is done
    return res.status(200).json({ status: "ok" });
  }
  return res.status(405).json({ error: "Method not allowed" });
}
