{
  "version": 2,
  "functions": {
    "api/webhook.js": {
      "maxDuration": 30,
      "memory": 256
    },
    "api/razorpay-webhook.js": {
      "maxDuration": 10,
      "memory": 128
    },
    "api/cron/process-meal-plans.js": {
      "maxDuration": 60,
      "memory": 256
    },
    "api/cron/expiry-reminder.js": {
      "maxDuration": 60,
      "memory": 256
    }
  },
  "crons": [
    {
      "path": "/api/cron/process-meal-plans",
      "schedule": "30 13 * * *"
    },
    {
      "path": "/api/cron/expiry-reminder",
      "schedule": "0 8 * * *"
    }
  ]
}
