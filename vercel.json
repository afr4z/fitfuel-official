{
  "version": 2,
  "functions": {
    "api/webhook.js": {
      "maxDuration": 30,
      "memory": 256
    },
    "api/razorpay-webhook.js": {
      "maxDuration": 10,
      "memory": 128
    },
    "api/cron/commit-meals.js": {
      "maxDuration": 120,
      "memory": 256
    },
    "api/cron/notify-breakfast.js": {
      "maxDuration": 60,
      "memory": 256
    },
    "api/cron/notify-lunch.js": {
      "maxDuration": 60,
      "memory": 256
    },
    "api/cron/notify-dinner.js": {
      "maxDuration": 60,
      "memory": 256
    },
    "api/cron/expiry-reminder.js": {
      "maxDuration": 60,
      "memory": 256
    },
    "api/cron/session-expiry.js": {
      "maxDuration": 30,
      "memory": 128
    }
  },
  "crons": [
    {
      "path": "/api/cron/commit-meals",
      "schedule": "15 14 * * *"
    },
    {
      "path": "/api/cron/notify-breakfast",
      "schedule": "30 14 * * *"
    },
    {
      "path": "/api/cron/notify-lunch",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/notify-dinner",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/cron/expiry-reminder",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/session-expiry",
      "schedule": "*/5 * * * *"
    }
  ]
}
